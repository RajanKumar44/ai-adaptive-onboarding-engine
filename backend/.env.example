# AI Adaptive Onboarding Engine - Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection details
# Default: localhost:5432
# For Docker: Use 'postgres' as hostname (service name from docker-compose)
# For Cloud: Use cloud database endpoint

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_onboarding

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Set to False in production
DEBUG=True

# Application metadata
APP_NAME=AI Adaptive Onboarding Engine
APP_VERSION=1.0.0

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
# Directory to store uploaded files (optional, for future use)
UPLOAD_DIR=./uploads

# Maximum file size in bytes (default: 10MB)
# 10485760 = 10 * 1024 * 1024
MAX_FILE_SIZE=10485760

# ============================================================================
# JWT AUTHENTICATION CONFIGURATION
# ============================================================================
# Secret key for JWT tokens
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MUST be changed in production!
JWT_SECRET_KEY=your-secret-key-change-in-production-do-not-use-this

# JWT token expiration in minutes (default: 30 minutes)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# JWT refresh token expiration in days (default: 7 days)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins (no spaces after commas)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:3001

# ============================================================================
# RATE LIMITING CONFIGURATION
# ============================================================================
# Enable or disable rate limiting
RATE_LIMIT_ENABLED=True

# Rate limit: requests per minute (default: 60)
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Rate limit: requests per hour (default: 1000)
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ============================================================================
# API KEY AUTHENTICATION
# ============================================================================
# Comma-separated list of valid API keys for API key authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable API key authentication
API_KEYS=

# ============================================================================
# PASSWORD POLICY CONFIGURATION
# ============================================================================
# Minimum password length (default: 8)
PASSWORD_MIN_LENGTH=8

# Require uppercase letters (default: True)
PASSWORD_REQUIRE_UPPERCASE=True

# Require lowercase letters (default: True)  
PASSWORD_REQUIRE_LOWERCASE=True

# Require digits (default: True)
PASSWORD_REQUIRE_DIGITS=True

# Require special characters (default: True)
PASSWORD_REQUIRE_SPECIAL=True

# ============================================================================
# LLM CONFIGURATION (for future integration)
# ============================================================================
# Which LLM provider to use: openai, anthropic, google, etc.
LLM_PROVIDER=openai

# Your API key for LLM (leave empty if not using LLM-based extraction)
# Get from: https://platform.openai.com/api-keys
LLM_API_KEY=

# ============================================================================
# LOGGING CONFIGURATION (PHASE 3)
# ============================================================================
# Running environment: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: colored (development) or json (production)
# Use "colored" for readable console output in development
# Use "json" for machine-readable structured logs in production
LOG_FORMAT=colored

# Log directory (relative to app root)
LOG_DIR=./logs

# Maximum log file size in bytes before rotation (default: 100MB)
LOG_MAX_BYTES=104857600

# Number of backup log files to keep (default: 10)
LOG_BACKUP_COUNT=10

# Enable request logging (logs all HTTP requests)
LOG_REQUESTS_ENABLED=True

# Enable response logging (logs HTTP responses)
LOG_RESPONSES_ENABLED=True

# Log request body (be careful with sensitive data) - keep False in production
LOG_REQUEST_BODY_ENABLED=False

# Log response body (be careful with sensitive data) - keep False in production
LOG_RESPONSE_BODY_ENABLED=False

# ============================================================================
# ERROR TRACKING CONFIGURATION (SENTRY)
# ============================================================================
# Sentry DSN for error tracking
# Get from: https://sentry.io
# Leave empty to disable Sentry error tracking
SENTRY_DSN=

# Sentry environment (will auto-detect from ENVIRONMENT if not set)
SENTRY_ENVIRONMENT=development

# Sample rate for transaction tracing (0.0 - 1.0)
# 0.1 = trace 10% of transactions (recommended for production)
SENTRY_TRACES_SAMPLE_RATE=0.1

# Sample rate for profiling (0.0 - 1.0)
# 0.1 = profile 10% of transactions
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ============================================================================
# PROMETHEUS METRICS CONFIGURATION
# ============================================================================
# Enable Prometheus metrics collection
PROMETHEUS_ENABLED=True

# Port for Prometheus metrics scraping
PROMETHEUS_PORT=8001

# ============================================================================
# PERFORMANCE PROFILING CONFIGURATION
# ============================================================================
# Enable performance profiling (function timing, memory usage)
PROFILING_ENABLED=False

# Sample rate for performance profiling (0.0 - 1.0)
# Only applies if PROFILING_ENABLED=True
PROFILING_SAMPLE_RATE=0.1

# Threshold for detecting slow database queries (milliseconds)
SLOW_QUERY_THRESHOLD_MS=1000

# ============================================================================
# PAGINATION CONFIGURATION (PHASE 4)
# ============================================================================
# Default page size for list endpoints
DEFAULT_PAGE_SIZE=10

# Maximum allowed page size (limits max value of limit parameter)
MAX_PAGE_SIZE=100

# Minimum page size
MIN_PAGE_SIZE=1

# ============================================================================
# FILTERING & SORTING CONFIGURATION (PHASE 4)
# ============================================================================
# Maximum number of filters allowed in a single query
MAX_FILTERS_PER_QUERY=10

# Maximum number of values in an IN filter
MAX_IN_FILTER_VALUES=100

# Default sort order (asc or desc)
DEFAULT_SORT_ORDER=desc

# Maximum number of sort fields
MAX_SORT_FIELDS=3

# ============================================================================
# SEARCH CONFIGURATION (PHASE 4)
# ============================================================================
# Minimum search term length (prevents wildcard-only searches)
MIN_SEARCH_LENGTH=2

# Maximum search term length
MAX_SEARCH_LENGTH=500

# Search timeout in seconds
SEARCH_TIMEOUT_SECONDS=5.0

# Default search mode: simple, phrase, boolean, or fuzzy
DEFAULT_SEARCH_MODE=simple

# HTML tag to use for highlighting search matches (em, strong, mark)
SEARCH_HIGHLIGHT_TAG=mark

# Enable search highlighting in results
SEARCH_HIGHLIGHT_ENABLED=True

# ============================================================================
# BULK OPERATIONS CONFIGURATION (PHASE 4)
# ============================================================================
# Batch size for processing bulk operations
BULK_OPERATION_BATCH_SIZE=100

# Maximum number of items allowed in a single bulk operation request
BULK_OPERATION_MAX_ITEMS=1000

# Default mode for bulk operations: True = atomic (all-or-nothing), False = partial success allowed
BULK_OPERATION_ATOMIC_DEFAULT=True

# ============================================================================
# API DOCUMENTATION CONFIGURATION (PHASE 4)
# ============================================================================
# Enable OpenAPI documentation endpoints (/docs, /redoc, /openapi.json)
OPENAPI_ENABLED=True

# Include example values in API documentation
INCLUDE_REQUEST_EXAMPLES=True

INCLUDE_RESPONSE_EXAMPLES=True

# ============================================================================
# NOTES FOR DIFFERENT ENVIRONMENTS
# ============================================================================
# 
# LOCAL DEVELOPMENT:
# - Use localhost for POSTGRES_HOST
# - Set DEBUG=True
# - Use docker-compose for PostgreSQL
# - JWT_SECRET_KEY can be any value (not secure)
# - CORS_ORIGINS: http://localhost:3000
# - LOG_LEVEL: DEBUG for verbose logging
# - LOG_FORMAT: colored for readability
# - ENVIRONMENT: development
# - SENTRY_DSN: Leave empty (optional for local dev)
# - PROFILING_ENABLED: False (adds overhead)
#
# STAGING:
# - Use cloud database endpoint for POSTGRES_HOST
# - Set DEBUG=False
# - JWT_SECRET_KEY should be unique
# - Restrict CORS_ORIGINS to staging frontend
# - LOG_LEVEL: INFO
# - LOG_FORMAT: json (structured logs)
# - ENVIRONMENT: staging
# - SENTRY_DSN: Set to staging Sentry project
# - PROFILING_ENABLED: True (for testing before production)
#
# PRODUCTION (AWS/Azure/GCP):
# - Use cloud database endpoint for POSTGRES_HOST
# - Set DEBUG=False
# - Use strong password for POSTGRES_PASSWORD
# - Generate unique JWT_SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# - Restrict CORS_ORIGINS to your frontend domain only
# - Configure API_KEYS for service-to-service authentication
# - Use strong PASSWORD policy settings
# - Enable RATE_LIMIT=True
# - LOG_LEVEL: WARNING (reduce log volume)
# - LOG_FORMAT: json (machine-readable)
# - ENVIRONMENT: production
# - SENTRY_DSN: Set to production Sentry project
# - SENTRY_TRACES_SAMPLE_RATE: 0.05-0.1 (5-10% sampling)
# - PROFILING_ENABLED: True (with sample rate 0.01-0.05)
# - PROMETHEUS_ENABLED: True (for monitoring)
# - Ensure logs directory has sufficient disk space
# - Configure log rotation to prevent disk space issues
#

