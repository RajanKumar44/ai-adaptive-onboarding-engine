# AI Adaptive Onboarding Engine - Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection details
# Default: localhost:5432
# For Docker: Use 'postgres' as hostname (service name from docker-compose)
# For Cloud: Use cloud database endpoint

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_onboarding

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Set to False in production
DEBUG=True

# Application metadata
APP_NAME=AI Adaptive Onboarding Engine
APP_VERSION=1.0.0

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
# Directory to store uploaded files (optional, for future use)
UPLOAD_DIR=./uploads

# Maximum file size in bytes (default: 10MB)
# 10485760 = 10 * 1024 * 1024
MAX_FILE_SIZE=10485760

# ============================================================================
# LLM CONFIGURATION (for future integration)
# ============================================================================
# Which LLM provider to use: openai, anthropic, google, etc.
LLM_PROVIDER=openai

# Your API key for LLM (leave empty if not using LLM-based extraction)
# Get from: https://platform.openai.com/api-keys
LLM_API_KEY=

# ============================================================================
# SECURITY CONFIGURATION (for production)
# ============================================================================
# Secret key for JWT tokens (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
# SECRET_KEY=your-secret-key-here

# CORS origins that can access the API
# CORS_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# NOTES FOR DIFFERENT ENVIRONMENTS
# ============================================================================
# 
# LOCAL DEVELOPMENT:
# - Use localhost for POSTGRES_HOST
# - Set DEBUG=True
# - Use docker-compose for PostgreSQL
#
# DOCKER:
# - Use "postgres" as POSTGRES_HOST (service name from docker-compose)
# - Set DEBUG=True or False as needed
#
# PRODUCTION (AWS/Azure/GCP):
# - Use cloud database endpoint for POSTGRES_HOST
# - Set DEBUG=False
# - Use strong password for POSTGRES_PASSWORD
# - Generate unique SECRET_KEY
# - Configure CORS_ORIGINS properly
# - Add LLM_API_KEY if using AI features
#
# TESTING:
# - Use SQLite: "sqlite:///./test.db" (in code)
# - Or separate PostgreSQL test database
#
