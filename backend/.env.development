# Backend Configuration
APP_ENV=development
DEBUG=true
APP_NAME=AI Adaptive Onboarding Engine

# Database (SQLite for development when no Docker)
DATABASE_URL=sqlite:///./ai_onboarding.db
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=

# LLM Configuration (Optional)
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Security
JWT_SECRET_KEY=dev-secret-key-change-in-production-12345
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cache
CACHE_STRATEGY=memory
CACHE_TTL_SECONDS=3600

# Logging
LOG_LEVEL=INFO
