# Docker stack defaults for root docker-compose.yml

# Ports exposed on host
APP_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432

# Postgres credentials/database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=ai_onboarding
POSTGRES_HOST=db

# App behavior
APP_ENV=development
DEBUG=true
INIT_DB=true
ALEMBIC_UPGRADE=false
JWT_SECRET_KEY=change-me-in-production

# Frontend build-time values
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NAME=AI Adaptive Onboarding Engine
